{
  "manifest_version": 3,
  "name": "KGTU Oto Bot",
  "version": "1.0",
  "description": "BBB poll automation",
  "permissions": ["activeTab"],
  "host_permissions": [
    "*://*.gidatarim.edu.tr/*",
    "*://*.blindsidenetworks.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.gidatarim.edu.tr/*", 
        "*://*.blindsidenetworks.com/*", 
        "<all_urls>"
      ],
      "all_frames": true,
      "run_at": "document_idle",
      "js": ["content.js"]
    }
  ]
}